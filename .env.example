# =============================================================================
# YouTube MCP Extended - Environment Configuration Example
# =============================================================================
# Copy this file to .env and fill in your values
# This file contains all available configuration options for the server
#
# Documentation: https://github.com/denniswestermann/youtube_MetaData_MCP
# =============================================================================

# =============================================================================
# APPLICATION ENVIRONMENT
# =============================================================================

# Environment mode: development, production, test
NODE_ENV=development

# =============================================================================
# OAUTH CONFIGURATION (REQUIRED)
# =============================================================================
# Get these from Google Cloud Console (APIs & Services > Credentials)
# Guide: https://developers.google.com/youtube/v3/getting-started

# YouTube OAuth Client credentials
YOUTUBE_CLIENT_ID=your-client-id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your-client-secret

# OAuth redirect URI (must match Google Cloud Console configuration)
YOUTUBE_REDIRECT_URI=http://localhost:3000/callback

# OAuth scopes (comma-separated)
# Available scopes:
# - https://www.googleapis.com/auth/youtube (read access)
# - https://www.googleapis.com/auth/youtube.upload (upload and manage)
# - https://www.googleapis.com/auth/youtubepartner-channel-audit (audit)
YOUTUBE_OAUTH_SCOPES=https://www.googleapis.com/auth/youtube,https://www.googleapis.com/auth/youtube.upload

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# Encryption secret for OAuth tokens (HIGHLY RECOMMENDED for production)
# Generate a strong random string (at least 32 characters)
# Example: openssl rand -base64 32
OAUTH_ENCRYPTION_SECRET=your-strong-encryption-secret-here

# Custom token storage directory (optional)
# Default: tokens/ in project root
OAUTH_STORAGE_DIR=tokens

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log level: error, warn, info, debug
LOG_LEVEL=info

# Enable file logging (true/false)
ENABLE_FILE_LOGGING=false

# Log directory (when file logging is enabled)
LOG_DIR=logs

# =============================================================================
# YOUTUBE API CONFIGURATION
# =============================================================================

# Daily quota limit for YouTube API (default: 10000)
# Monitor usage at: https://console.cloud.google.com/apis/dashboard
YOUTUBE_QUOTA_LIMIT=10000

# Rate limiting - requests per second (default: 100)
YOUTUBE_RATE_LIMIT_RPS=100

# Rate limiting - requests per minute (default: 6000)
YOUTUBE_RATE_LIMIT_RPM=6000

# =============================================================================
# STORAGE CONFIGURATION
# =============================================================================

# Directory for video metadata backups
BACKUP_DIR=backups

# Directory for metadata suggestions storage
METADATA_SUGGESTIONS_DIR=storage/metadata-suggestions

# Temporary files directory
TEMP_DIR=temp

# =============================================================================
# MCP SERVER CONFIGURATION
# =============================================================================

# MCP server name (optional)
MCP_SERVER_NAME=youtube-mcp-extended

# MCP server version (optional)
MCP_SERVER_VERSION=1.0.0

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable/disable specific features using FEATURE_<FLAG_NAME>=true/false
# Flag names use UPPER_SNAKE_CASE conversion of camelCase names

# Core Features
FEATURE_ENABLE_O_AUTH=true
FEATURE_ENABLE_METADATA_GENERATION=true
FEATURE_ENABLE_VIDEO_SCHEDULING=true
FEATURE_ENABLE_PLAYLIST_MANAGEMENT=true
FEATURE_ENABLE_BACKUP_RESTORE=true
FEATURE_ENABLE_BATCH_OPERATIONS=true
FEATURE_ENABLE_THUMBNAIL_CONCEPTS=true

# Advanced Features
FEATURE_ENABLE_TRANSCRIPT_ANALYSIS=true
FEATURE_ENABLE_METADATA_VALIDATION=true
FEATURE_ENABLE_QUOTA_MONITORING=true
FEATURE_ENABLE_PERFORMANCE_METRICS=false
FEATURE_ENABLE_AUDIT_LOGGING=false

# Experimental Features (use with caution)
FEATURE_ENABLE_ADVANCED_SCHEDULING=false
FEATURE_ENABLE_CONTENT_ANALYSIS=false
FEATURE_ENABLE_AUTOMATIC_TAGGING=false
FEATURE_ENABLE_ML_OPTIMIZATION=false

# Development Features
FEATURE_ENABLE_DEBUG_MODE=false
FEATURE_ENABLE_MOCK_SERVICES=false
FEATURE_ENABLE_BETA_FEATURES=false
FEATURE_ENABLE_DEV_TOOLS=false

# Integration Features (future)
FEATURE_ENABLE_WEBHOOKS=false
FEATURE_ENABLE_API_EXTENSIONS=false
FEATURE_ENABLE_THIRD_PARTY_INTEGRATIONS=false

# Security Features
FEATURE_ENABLE_ENCRYPTION=true
FEATURE_ENABLE_RATE_LIMITING=true
FEATURE_ENABLE_INPUT_SANITIZATION=true
FEATURE_ENABLE_COMPLIANCE_MODE=false

# =============================================================================
# BACKWARD COMPATIBILITY
# =============================================================================
# These variables are supported for backward compatibility
# Use the YOUTUBE_* variants above for new setups

# Legacy Google OAuth variables (deprecated, use YOUTUBE_* instead)
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
# GOOGLE_REDIRECT_URI=http://localhost:3000/callback
# GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/youtube,https://www.googleapis.com/auth/youtube.upload

# =============================================================================
# ENVIRONMENT-SPECIFIC CONFIGURATIONS
# =============================================================================

# Development Environment
# - Debug logging enabled
# - Console logging enabled
# - File logging optional
# - Reduced rate limits for testing
# - Beta features available

# Production Environment
# - Console logging disabled (required for MCP)
# - File logging recommended
# - Encryption strongly recommended
# - Audit logging recommended
# - Beta features disabled

# Test Environment
# - Minimal logging
# - Mock services available
# - Reduced rate limits
# - Isolated storage directories

# =============================================================================
# ADDITIONAL NOTES
# =============================================================================

# 1. Environment Variable Priority:
#    - Command line environment variables override .env files
#    - .env.local overrides .env
#    - .env.{environment}.local overrides .env.{environment}
#    - .env.{environment} overrides .env

# 2. Google Cloud Console Setup:
#    - Enable YouTube Data API v3
#    - Create OAuth 2.0 credentials
#    - Add redirect URI to authorized redirect URIs
#    - Download client configuration or copy client ID/secret

# 3. Security Best Practices:
#    - Use OAUTH_ENCRYPTION_SECRET in production
#    - Keep client secrets secure and never commit to git
#    - Regularly rotate credentials
#    - Monitor API quota usage
#    - Enable audit logging in production

# 4. Troubleshooting:
#    - Use get_configuration_status tool to validate setup
#    - Check logs for configuration errors
#    - Verify OAuth redirect URI matches exactly
#    - Ensure YouTube API v3 is enabled in Google Cloud Console

# 5. Performance Tuning:
#    - Adjust rate limits based on your quota
#    - Enable performance metrics for monitoring
#    - Use appropriate log levels for your environment
#    - Configure storage directories on fast storage

# =============================================================================
# EXAMPLE CONFIGURATIONS
# =============================================================================

# High Volume Channel (1000+ videos):
# YOUTUBE_RATE_LIMIT_RPS=50
# YOUTUBE_RATE_LIMIT_RPM=3000
# BACKUP_DIR=backups/monthly
# FEATURE_ENABLE_PERFORMANCE_METRICS=true

# Low Volume Channel (< 100 videos):
# YOUTUBE_RATE_LIMIT_RPS=20
# YOUTUBE_RATE_LIMIT_RPM=1200
# FEATURE_ENABLE_QUOTA_MONITORING=false

# Security-Focused Setup:
# OAUTH_ENCRYPTION_SECRET=your-very-strong-secret-here
# FEATURE_ENABLE_AUDIT_LOGGING=true
# FEATURE_ENABLE_COMPLIANCE_MODE=true
# LOG_LEVEL=warn

# Development Setup:
# LOG_LEVEL=debug
# ENABLE_FILE_LOGGING=true
# FEATURE_ENABLE_DEBUG_MODE=true
# FEATURE_ENABLE_DEV_TOOLS=true
# FEATURE_ENABLE_BETA_FEATURES=true