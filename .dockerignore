# YouTube MCP Extended - Docker ignore file

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Production build
dist/
build/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pids/
*.pid
*.seed
*.pid.lock

# Runtime data
pids/
*.pid
*.seed
*.pid.lock
lib-cov/
coverage/
.nyc_output/
.grunt/
bower_components/
.lock-wscript/
build/Release/
node_modules/
jspm_packages/
typings/
.npm/
.eslintcache/
.node_repl_history/
*.tgz/
.yarn-integrity/

# Sensitive data directories
tokens/
backups/
storage/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Git
.git/
.gitignore

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# Documentation
README.md
docs/
*.md
!PRODUCTION.md

# Test files
tests/
__tests__/
**/*.test.ts
**/*.spec.ts
jest.config.js
vitest.config.ts

# Temporary files
tmp/
temp/
.tmp/

# Cache directories
.cache/
.parcel-cache/

# Build tools
.webpack/
.rollup.cache/

# Development tools
.eslintrc*
.prettierrc*
tsconfig*.json
!tsconfig.json

# Scripts (except production ones)
scripts/dev/
scripts/build/
!scripts/deploy/
!scripts/install/

# Examples and demos
examples/
demo/

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
.circleci/

# Package manager lock files (keep package-lock.json for npm)
yarn.lock
pnpm-lock.yaml

# Agents (build-time only, exclude from runtime)
agents/buildops/
agents/testing/
agents/documentation/