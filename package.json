{
  "name": "youtube-mcp-extended",
  "version": "0.0.2",
  "description": "Extended YouTube MCP Server with AI-powered metadata optimization, strategic scheduling, and playlist management for Claude Desktop",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx agents/buildops/build-scripts.ts dev",
    "dev:basic": "tsx watch src/index.ts",
    "dev:debug": "NODE_OPTIONS='--inspect' tsx agents/buildops/build-scripts.ts dev",
    "dev:inspect": "NODE_OPTIONS='--inspect-brk' tsx watch src/index.ts",
    "build": "tsx agents/buildops/build-scripts.ts build",
    "build:basic": "tsc",
    "build:dev": "tsx agents/buildops/build-scripts.ts build --mode=development",
    "build:prod": "tsx agents/buildops/build-scripts.ts build --mode=production",
    "build:watch": "tsx agents/buildops/build-scripts.ts watch",
    "build:analyze": "tsx agents/buildops/build-scripts.ts analyze",
    "build:deploy": "tsx agents/buildops/build-scripts.ts deploy",
    "start": "node dist/index.js",
    "start:dev": "tsx watch src/index.ts",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "validate:env": "tsx agents/buildops/env-validator.ts",
    "generate:env": "tsx agents/buildops/env-validator.ts generate-env",
    "lint": "eslint src --ext .ts --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run src/__tests__",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest --watch --config vitest.integration.config.ts",
    "test:integration:coverage": "vitest run --coverage --config vitest.integration.config.ts",
    "test:all": "npm run test:unit && npm run test:integration",
    "test:ci": "vitest run --coverage --reporter=verbose",
    "check": "npm run type-check && npm run lint && npm run test:unit",
    "check:all": "npm run type-check && npm run lint && npm run test:all",
    "precommit": "npm run format && npm run lint:fix && npm run type-check",
    "prepush": "npm run check",
    "audit": "npm audit && npm run audit:licenses",
    "audit:licenses": "npx license-checker --summary",
    "security": "npm audit --audit-level moderate",
    "clean": "rm -rf dist",
    "clean:all": "npm run clean && rm -rf node_modules package-lock.json",
    "reset": "npm run clean:all && npm install",
    "version:patch": "npm version patch && git push --tags",
    "version:minor": "npm version minor && git push --tags",
    "version:major": "npm version major && git push --tags",
    "docker:build": "docker build -t youtube-mcp-extended .",
    "docker:run": "docker run -p 3000:3000 youtube-mcp-extended",
    "docker:dev": "docker-compose up --build",
    "docker:prod": "docker-compose -f docker-compose.prod.yml up --build",
    "deploy": "npm run build:deploy && npm run docker:build",
    "prepublishOnly": "npm run clean && npm run build && npm run check"
  },
  "keywords": [
    "youtube",
    "mcp",
    "model-context-protocol",
    "claude",
    "ai",
    "metadata",
    "scheduling",
    "automation"
  ],
  "author": "Dennis Westermann (aiEX Academy)",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "google-auth-library": "^9.0.0",
    "googleapis": "^130.0.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^8.56.0",
    "prettier": "^3.1.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0",
    "vitest": "^1.1.0"
  }
}
